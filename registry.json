        },
        "@keyframes mask-button-out": {
          "from": {
            "-webkit-mask-position": "100% 0",
            "mask-position": "100% 0"
          },
          "to": {
            "-webkit-mask-position": "0 0",
            "mask-position": "0 0"
          }
        }
      }
